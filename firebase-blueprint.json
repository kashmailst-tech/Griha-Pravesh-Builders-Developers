{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A residential project listing",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Name of the project" },
        "location": { "type": "string", "description": "Location in Ghaziabad" },
        "price": { "type": "string", "description": "Price range" },
        "type": { "type": "string", "description": "Property type (e.g. 2BHK)" },
        "area": { "type": "string", "description": "Area in sq.ft" },
        "status": { "type": "string", "enum": ["Ready to Move", "Under Construction", "New Launch"] },
        "image": { "type": "string", "format": "url" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "location", "price", "type", "area", "status", "image"]
    },
    "Inquiry": {
      "title": "Inquiry",
      "description": "A lead or inquiry for a project",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "projectId": { "type": "string" },
        "projectTitle": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "status": { "type": "string", "enum": ["New", "Contacted", "Site Visit", "Closed"] },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "customerName", "customerPhone", "status", "date"]
    },
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] }
      },
      "required": ["uid", "role"]
    },
    "Favorite": {
      "title": "Favorite",
      "description": "A user's favorite property",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "projectTitle": { "type": "string" },
        "price": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["projectId"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of all property projects"
    },
    "/inquiries/{inquiryId}": {
      "schema": "Inquiry",
      "description": "Collection of customer inquiries"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/users/{userId}/favorites/{favoriteId}": {
      "schema": "Favorite",
      "description": "User's saved properties"
    }
  }
}
